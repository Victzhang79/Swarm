<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.alarm.mapper.AlarmAppMapper">

    <resultMap type="com.ruoyi.alarm.domain.AlarmApp" id="AlarmAppResult">
        <result property="appId" column="app_id"/>
        <result property="appName" column="app_name"/>
        <result property="appSecret" column="app_secret"/>
        <result property="status" column="status"/>
        <result property="expireTime" column="expire_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectAlarmAppVo">
        app_id, app_name, app_secret, status, expire_time, create_by, create_time, update_by, update_time, remark
    </sql>

    <select id="selectAlarmAppList" parameterType="com.ruoyi.alarm.domain.AlarmApp" resultMap="AlarmAppResult">
        select <include refid="selectAlarmAppVo"/>
        from alarm_app
        <where>
            <if test="appName != null and appName != ''">
                and app_name like concat('%', #{appName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by app_id desc
    </select>

    <select id="selectAlarmAppById" parameterType="Long" resultMap="AlarmAppResult">
        select <include refid="selectAlarmAppVo"/>
        from alarm_app
        where app_id = #{appId}
    </select>

    <select id="selectAlarmAppByAppId" parameterType="Long" resultMap="AlarmAppResult">
        select <include refid="selectAlarmAppVo"/>
        from alarm_app
        where app_id = #{appId}
    </select>

    <insert id="insertAlarmApp" parameterType="com.ruoyi.alarm.domain.AlarmApp" useGeneratedKeys="true" keyProperty="appId">
        insert into alarm_app
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="appName != null and appName != ''">app_name,</if>
            <if test="appSecret != null and appSecret != ''">app_secret,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix=") values(" suffix=")">
            <if test="appName != null and appName != ''">#{appName},</if>
            <if test="appSecret != null and appSecret != ''">#{appSecret},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateAlarmApp" parameterType="com.ruoyi.alarm.domain.AlarmApp">
        update alarm_app
        <trim prefix="SET" suffixOverrides=",">
            <if test="appName != null and appName != ''">app_name = #{appName},</if>
            <if test="appSecret != null and appSecret != ''">app_secret = #{appSecret},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </trim>
        where app_id = #{appId}
    </update>

    <delete id="deleteAlarmAppById" parameterType="Long">
        delete from alarm_app where app_id = #{appId}
    </delete>

    <delete id="deleteAlarmAppByIds" parameterType="Long">
        delete from alarm_app where app_id in
        <foreach collection="array" item="appId" separator="," open="(" close=")">
            #{appId}
        </foreach>
    </delete>

</mapper>
