<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.alarm.mapper.AlarmScheduleSnapshotMapper">

    <resultMap type="AlarmScheduleSnapshot" id="AlarmScheduleSnapshotResult">
        <result property="snapshotId"     column="snapshot_id"     />
        <result property="taskId"         column="task_id"         />
        <result property="strategyId"     column="strategy_id"     />
        <result property="dutyDate"       column="duty_date"       />
        <result property="scheduleSource" column="schedule_source" />
        <result property="groupId"        column="group_id"        />
        <result property="memberIds"      column="member_ids"      />
        <result property="isManualOverride" column="is_manual_override" />
        <result property="notifyStatus"   column="notify_status"   />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
    </resultMap>

    <sql id="selectSnapshotVo">
        select snapshot_id, task_id, strategy_id, duty_date, schedule_source, group_id, member_ids, is_manual_override, notify_status, create_by, create_time, update_by, update_time
        from alarm_schedule_snapshot
    </sql>

    <select id="selectSnapshotList" parameterType="AlarmScheduleSnapshot" resultMap="AlarmScheduleSnapshotResult">
        <include refid="selectSnapshotVo"/>
        <where>
            <if test="taskId != null">
                and task_id = #{taskId}
            </if>
            <if test="strategyId != null">
                and strategy_id = #{strategyId}
            </if>
            <if test="dutyDate != null">
                and duty_date = #{dutyDate}
            </if>
            <if test="scheduleSource != null and scheduleSource != ''">
                and schedule_source = #{scheduleSource}
            </if>
            <if test="groupId != null">
                and group_id = #{groupId}
            </if>
            <if test="isManualOverride != null and isManualOverride != ''">
                and is_manual_override = #{isManualOverride}
            </if>
            <if test="notifyStatus != null and notifyStatus != ''">
                and notify_status = #{notifyStatus}
            </if>
        </where>
        order by duty_date desc, create_time desc
    </select>

    <select id="selectSnapshotById" parameterType="Long" resultMap="AlarmScheduleSnapshotResult">
        <include refid="selectSnapshotVo"/>
        where snapshot_id = #{snapshotId}
    </select>

    <select id="selectSnapshotByDateAndStrategy" resultMap="AlarmScheduleSnapshotResult">
        <include refid="selectSnapshotVo"/>
        where duty_date = #{dutyDate}
        and strategy_id = #{strategyId}
    </select>

    <insert id="insertSnapshot" parameterType="AlarmScheduleSnapshot" useGeneratedKeys="true" keyProperty="snapshotId">
        insert into alarm_schedule_snapshot
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="strategyId != null">strategy_id,</if>
            <if test="dutyDate != null">duty_date,</if>
            <if test="scheduleSource != null and scheduleSource != ''">schedule_source,</if>
            <if test="groupId != null">group_id,</if>
            <if test="memberIds != null and memberIds != ''">member_ids,</if>
            <if test="isManualOverride != null and isManualOverride != ''">is_manual_override,</if>
            <if test="notifyStatus != null and notifyStatus != ''">notify_status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="strategyId != null">#{strategyId},</if>
            <if test="dutyDate != null">#{dutyDate},</if>
            <if test="scheduleSource != null and scheduleSource != ''">#{scheduleSource},</if>
            <if test="groupId != null">#{groupId},</if>
            <if test="memberIds != null and memberIds != ''">#{memberIds},</if>
            <if test="isManualOverride != null and isManualOverride != ''">#{isManualOverride},</if>
            <if test="notifyStatus != null and notifyStatus != ''">#{notifyStatus},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateSnapshot" parameterType="AlarmScheduleSnapshot">
        update alarm_schedule_snapshot
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="strategyId != null">strategy_id = #{strategyId},</if>
            <if test="dutyDate != null">duty_date = #{dutyDate},</if>
            <if test="scheduleSource != null and scheduleSource != ''">schedule_source = #{scheduleSource},</if>
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="memberIds != null and memberIds != ''">member_ids = #{memberIds},</if>
            <if test="isManualOverride != null and isManualOverride != ''">is_manual_override = #{isManualOverride},</if>
            <if test="notifyStatus != null and notifyStatus != ''">notify_status = #{notifyStatus},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where snapshot_id = #{snapshotId}
    </update>

    <update id="updateManualOverride">
        update alarm_schedule_snapshot
        set group_id = #{groupId},
            member_ids = #{memberIds},
            is_manual_override = '1',
            schedule_source = 'manual',
            update_time = now()
        where snapshot_id = #{snapshotId}
    </update>

    <update id="updateNotifyStatus">
        update alarm_schedule_snapshot
        set notify_status = #{notifyStatus},
            update_time = now()
        where snapshot_id = #{snapshotId}
    </update>

    <delete id="deleteSnapshotByIds" parameterType="Long">
        delete from alarm_schedule_snapshot where snapshot_id in
        <foreach collection="array" item="snapshotId" open="(" separator="," close=")">
            #{snapshotId}
        </foreach>
    </delete>

</mapper>
