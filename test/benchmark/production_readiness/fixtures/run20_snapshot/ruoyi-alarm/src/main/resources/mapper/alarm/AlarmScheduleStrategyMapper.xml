<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.alarm.mapper.AlarmScheduleStrategyMapper">

    <resultMap type="AlarmScheduleStrategy" id="AlarmScheduleStrategyResult">
        <result property="strategyId"     column="strategy_id"     />
        <result property="strategyName"   column="strategy_name"   />
        <result property="strategyMode"   column="strategy_mode"   />
        <result property="groupCount"     column="group_count"     />
        <result property="status"         column="status"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectScheduleStrategyVo">
        select strategy_id, strategy_name, strategy_mode, group_count, status, create_by, create_time, update_by, update_time, remark
        from alarm_schedule_strategy
    </sql>

    <select id="selectScheduleStrategyList" parameterType="AlarmScheduleStrategy" resultMap="AlarmScheduleStrategyResult">
        <include refid="selectScheduleStrategyVo"/>
        <where>
            <if test="strategyName != null and strategyName != ''">
                and strategy_name like concat('%', #{strategyName}, '%')
            </if>
            <if test="strategyMode != null and strategyMode != ''">
                and strategy_mode = #{strategyMode}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectScheduleStrategyById" parameterType="Long" resultMap="AlarmScheduleStrategyResult">
        <include refid="selectScheduleStrategyVo"/>
        where strategy_id = #{strategyId}
    </select>

    <insert id="insertScheduleStrategy" parameterType="AlarmScheduleStrategy" useGeneratedKeys="true" keyProperty="strategyId">
        insert into alarm_schedule_strategy
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="strategyName != null and strategyName != ''">strategy_name,</if>
            <if test="strategyMode != null and strategyMode != ''">strategy_mode,</if>
            <if test="groupCount != null">group_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="strategyName != null and strategyName != ''">#{strategyName},</if>
            <if test="strategyMode != null and strategyMode != ''">#{strategyMode},</if>
            <if test="groupCount != null">#{groupCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateScheduleStrategy" parameterType="AlarmScheduleStrategy">
        update alarm_schedule_strategy
        <trim prefix="SET" suffixOverrides=",">
            <if test="strategyName != null and strategyName != ''">strategy_name = #{strategyName},</if>
            <if test="strategyMode != null and strategyMode != ''">strategy_mode = #{strategyMode},</if>
            <if test="groupCount != null">group_count = #{groupCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </trim>
        where strategy_id = #{strategyId}
    </update>

    <delete id="deleteScheduleStrategyById" parameterType="Long">
        delete from alarm_schedule_strategy where strategy_id = #{strategyId}
    </delete>

    <delete id="deleteScheduleStrategyByIds" parameterType="Long">
        delete from alarm_schedule_strategy where strategy_id in
        <foreach collection="array" item="strategyId" open="(" separator="," close=")">
            #{strategyId}
        </foreach>
    </delete>

    <delete id="deleteGroupByStrategyId" parameterType="Long">
        delete from alarm_schedule_group where strategy_id = #{strategyId}
    </delete>

</mapper>
