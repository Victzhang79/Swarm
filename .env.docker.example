# Swarm Docker 一键部署 —— 环境变量模板。
# 用法: cp .env.docker.example .env  然后按需填值。
# .env 已被 .gitignore / .dockerignore 排除，绝不入库 / 不进镜像。

# ─── PostgreSQL（compose 内置，容器间互联）───────────────
# 生产务必改强口令；改后 SWARM_DB_POSTGRES_URI 会自动用这里的值拼接。
POSTGRES_USER=swarm
POSTGRES_PASSWORD=swarm
POSTGRES_DB=swarm

# ─── 对外端口 ─────────────────────────────────────────
SWARM_PORT=8420

# ─── RBAC（生产建议 true；开发/试用可 false 走匿名 admin 开箱即用）──
SWARM_RBAC_ENABLED=true

# ─── 热沙箱池 ─────────────────────────────────────────
SWARM_SANDBOX_POOL_ENABLED=true
# 多副本时各填唯一值做沙箱隔离；单机留空自动随机 UUID
SWARM_INSTANCE_ID=

# ─── CubeSandbox 远程沙箱执行服务器（独立服务器，不在 compose）──────
# Worker 经 dev_sidecar 代理连它跑用户代码。架构不动、不容器化。
# 留空则 Worker 无法派发到沙箱（仅本地 difflib 兜底）。填入你的实际部署值：
SWARM_SANDBOX_API_URL=
SWARM_SANDBOX_API_KEY=
# dev_sidecar 代理基址（如 http://<your-sidecar-host>:3000）
SWARM_SANDBOX_PROXY_BASE=
# 默认沙箱模板 ID（CubeSandbox 上预置的镜像模板）
SWARM_SANDBOX_DEFAULT_TEMPLATE=

# ─── 模型接入点 / 其它密钥 ────────────────────────────
# 推荐登录后在 WebUI「设置」里配置（落 secret_store 加密、保存即 reload）。
# 也可在此用 env 提供，例如：
# OPENAI_API_KEY=
# SILICONFLOW_API_KEY=
