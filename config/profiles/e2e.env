# F3（阶段7）e2e profile——E2E 验证推荐组合（生产同拓扑：PG checkpointer+冒烟+闸门全开）。
# 真拓扑：Redis enabled + Sandbox=CubeMaster；密钥/端点在 .env 本体，profile 只冻结开关组合。
SWARM_REQUIRE_PG_CHECKPOINTER=1
SWARM_AUTO_ACCEPT=1
SWARM_RUNTIME_SMOKE_ENABLED=1
SWARM_RUNTIME_SMOKE_PLATEAU_STRICT=1
SWARM_PLAN_COVERAGE_GATE=1
SWARM_WORKER_L1_LINT_GATE=1
SWARM_WORKER_DEP_REPAIR=1
SWARM_SANDBOX_POOL_ENABLED=1
SWARM_REQUIRE_SECRET_KEY=1
SWARM_EXTRACT_MAX_ITEMS=150
SWARM_SKILLS_ADMIT_LLM_JUDGE=1
