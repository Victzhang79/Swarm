# ─── Python ───────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.python-version

# ─── 虚拟环境 ─────────────────────────────
.venv/

# ─── 密钥 / 环境（绝不入库）─────────────────
.env
.env.local
*.key
*.pem

# ─── 工具缓存 ─────────────────────────────
.pytest_cache/
.ruff_cache/
.hermes/

# ─── 运行时产物 / 数据 ────────────────────
.codegraph/
.qdrant-initialized
qdrant.log
swarm.log
*.log
*.log.*
logs/
snapshots/
workspace/
# greenfield 从零创建的项目内容（保留目录本身，忽略生成内容）
workdir/*
!workdir/.gitkeep

# ─── OS ───────────────────────────────────
.DS_Store

# ─── 内部开发日志（本地保留，不入库；GitHub README 用面向用户的版本）──
DEVLOG.md

# ─── 本地研发资料：界首 / 交接 / 就绪度 / 随跑日志（本地保留，不入库）──
E2E_*.md
*_HANDOFF.md
*_KICKOFF.md
*_TREATMENT_PLAN.md
*_READINESS.md
*_PROGRESS.md
UPSTREAM_DOWNSTREAM_TREATMENT.md
logs_archive/
