qdrant.log
swarm.log
*.log
*.log.*
logs/
snapshots/
workspace/
# greenfield 从零创建的项目内容（保留目录本身，忽略生成内容）
workdir/*
!workdir/.gitkeep

# ─── OS ───────────────────────────────────
.DS_Store

# ─── 内部开发日志（本地保留，不入库；GitHub README 用面向用户的版本）──
DEVLOG.md

