# ──────────────────────────────────────────────
# Swarm 环境配置 — 复制为 .env 后填入真实值
# cp .env.example .env
# ──────────────────────────────────────────────

# 数据库
SWARM_DB_POSTGRES_URI=postgresql://localhost:5432/swarm
SWARM_DB_REDIS_URI=redis://localhost:6379/0
SWARM_DB_QDRANT_URL=http://localhost:6333

# 模型 — SiliconFlow（云端大模型）
SWARM_MODEL_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SWARM_MODEL_SILICONFLOW_API_KEY=                          # ← 填入你的 SiliconFlow API Key

# 模型 — 本地推理服务器
SWARM_MODEL_LOCAL_BASE_URL=http://localhost:11434/v1      # 或你的 OpenWebUI 地址
SWARM_MODEL_LOCAL_API_KEY=                                # ← 本地 API Key（如不需要可留空）

# Brain 编排层
SWARM_MODEL_BRAIN_PRIMARY=Pro/zai-org/GLM-5.1
SWARM_MODEL_BRAIN_FALLBACK=moonshotai/Kimi-K2.6
SWARM_MODEL_BRAIN_TEMPERATURE=0.3
SWARM_MODEL_TIMEOUT_SECONDS=120
SWARM_MODEL_MAX_RETRIES=2

# Worker 执行器
SWARM_MODEL_WORKER_PRIMARY=MiniMax-M2.7-Pro
SWARM_MODEL_WORKER_LOCAL=qwen3:27b
SWARM_MODEL_WORKER_TEMPERATURE=0.2

# ─── 模型路由表 ───
SWARM_MODEL_ROUTING_TRIVIAL=Qwen3.6-27B-Saka-NVFP4
SWARM_MODEL_ROUTING_TRIVIAL_FALLBACK=Step-3.7-Flash
SWARM_MODEL_ROUTING_MEDIUM=MiniMax-M2.7-Pro
SWARM_MODEL_ROUTING_MEDIUM_FALLBACK=Qwen3.5-122B-A10B-NVFP4
SWARM_MODEL_ROUTING_COMPLEX=Pro/zai-org/GLM-5.1
SWARM_MODEL_ROUTING_COMPLEX_FALLBACK=moonshotai/Kimi-K2.6
SWARM_MODEL_ROUTING_MULTIMODAL=Qwen3.6-27B-Saka-NVFP4-multimodal
SWARM_MODEL_ROUTING_MULTIMODAL_FALLBACK=MiniMax-M2.7-Pro
# 流式无 chunk 看门狗秒数（远端 stall 时多快中断转 fallback；默认 45）
# SWARM_MODEL_STREAM_CHUNK_TIMEOUT=45

# Worker
SWARM_WORKER_MAX_CONCURRENT=4
SWARM_WORKER_MAX_EXECUTION_TIME=600
SWARM_WORKER_MAX_ITERATIONS=50
SWARM_WORKER_MAX_FIX_ROUNDS=3

# Worker L1 确定性验证闸门（默认全开 = 硬阻断；改 false 可降级，但会削弱质量保证）
# SWARM_WORKER_L1_LINT=true         # L1.2.5 lint（ruff/eslint）；false=跳过
# SWARM_WORKER_L1_LINT_GATE=true    # lint 语法级 error 是否硬阻断；false=仅警告
# SWARM_WORKER_L1_SELF_REVIEW=true  # L1.4 LLM 自检（不硬阻断，仅警告）
# 全局命令白名单（逗号分隔前缀）；每个子任务的 harness.extra_whitelist 会在其上追加
# SWARM_WORKER_COMMAND_WHITELIST=mvn compile,mvn test,npm build,npm test,python -m py_compile,python -m pytest,tsc --noEmit,eslint,javac

# API / 自动化（任务主链路默认等待人工审核；Demo/E2E 可设 true）
# SWARM_AUTO_ACCEPT=true
# SWARM_API_URL=http://127.0.0.1:8420   # CLI swarm submit / worker-run 默认地址

# 知识库
SWARM_KB_EMBEDDING_MODEL=BAAI/bge-m3
SWARM_KB_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# CubeSandbox 远程沙箱（Worker 沙箱优先执行，见 README）
# SWARM_SANDBOX_API_URL=http://192.168.60.106:3000
# SWARM_SANDBOX_PROXY_BASE=https://192.168.60.106:443
# SWARM_SANDBOX_DEFAULT_TEMPLATE=tpl-xxxxxxxx
# SWARM_SANDBOX_USE_FOR_WORKER=true
# SWARM_SANDBOX_SANDBOX_FIRST=true
# SWARM_SANDBOX_SANDBOX_REMOTE_WORKDIR=/workspace
# SWARM_SANDBOX_POOL_ENABLED=true   # 沙箱热池：预热复用，省去每任务冷启动（池状态见系统 tab / GET /api/sandbox/pool）

# LangSmith 追踪（LangChain / LangGraph）
# SWARM_LANGSMITH_TRACING=true
# SWARM_LANGSMITH_API_KEY=lsv2_xxx
# SWARM_LANGSMITH_PROJECT=swarm-dev
# SWARM_LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 日志系统（统一 swarm/logging_config.py；不配则用默认）
# SWARM_LOG_LEVEL=INFO              # DEBUG/INFO/WARNING/ERROR
# SWARM_LOG_FILE=swarm.log          # 相对项目根或绝对路径；空串=仅控制台
# SWARM_LOG_JSON=false              # true=结构化 JSON 行日志（便于 ELK/Loki）
# SWARM_LOG_MAX_BYTES=20000000      # 单文件上限，超过轮转
# SWARM_LOG_BACKUP_COUNT=5          # 保留轮转文件数
# SWARM_LOG_CONSOLE=true            # 是否同时输出控制台（API 进程自动关闭以免双写）

# L3 预发环境验证（Phase 5，可选；未配置则 verify_l3 跳过）
# SWARM_STAGING_URL=https://staging.example.com/health

# L3 GitLab CI/CD（配置后优先于 STAGING_URL）
# SWARM_GITLAB_URL=https://gitlab.example.com
# SWARM_GITLAB_TOKEN=glpat-xxx
# SWARM_GITLAB_PROJECT_ID=group/project
# SWARM_GITLAB_TRIGGER_TOKEN=   # 可选 trigger token
# SWARM_GITLAB_REF=main
# SWARM_GITLAB_PUSH_ENABLED=false   # true 时 L3 先将 merged_diff push 到 swarm/l3-{task_id} 再触发 pipeline
# SWARM_GITLAB_MR_ON_ACCEPT=false   # true 时 learn_success 自动创建 GitLab MR 草稿

# Redis 平台（P2 — 可选）
# SWARM_REDIS_ENABLED=false
# SWARM_DB_REDIS_URI=redis://localhost:6379/0

# 多用户 RBAC（默认开启；Web UI 登录 admin / swarm）
# SWARM_RBAC_ENABLED=true
# SWARM_BOOTSTRAP_ADMIN_PASSWORD=swarm
# SWARM_BOOTSTRAP_RESET_ADMIN_PASSWORD=false

# 遗留单 Key（与 user token 等效 admin，可选）
# SWARM_API_KEY=

# 单任务 token 估算硬上限（默认 500000）
# SWARM_MAX_TASK_TOKENS=500000

# Memory L3 — Brain 滑动窗口上下文压缩（非 verify_l3 节点）
# SWARM_CONTEXT_MAX_TOKENS=80000
# SWARM_CONTEXT_RESERVE_TOKENS=16000
